{
    "name": "codedmonkey/dirigent",
    "description": "A free and open package registry for Composer",
    "type": "project",
    "license": "FSL-1.1-MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-curl": "*",
        "ext-iconv": "*",
        "ext-sodium": "*",
        "cebe/markdown": "^1.2.1",
        "composer/composer": "^2.9.8",
        "composer/pcre": "^3.3.2",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.2",
        "easycorp/easyadmin-bundle": "^5.0.9",
        "endroid/qr-code": "^6.0.9",
        "league/commonmark": "^2.8.2",
        "phpstan/phpdoc-parser": "^2.3.2",
        "scheb/2fa-bundle": "^8.5.0",
        "scheb/2fa-totp": "^8.5.0",
        "sentry/sentry-symfony": "^5.9",
        "symfony/asset": "^8.1.0",
        "symfony/console": "^8.1.0",
        "symfony/doctrine-messenger": "^8.1.0",
        "symfony/dotenv": "^8.1.0",
        "symfony/expression-language": "^8.1.0",
        "symfony/flex": "^2.10",
        "symfony/form": "^8.1.0",
        "symfony/framework-bundle": "^8.1.0",
        "symfony/http-client": "^8.1.0",
        "symfony/intl": "^8.1.0",
        "symfony/mailer": "^8.1.0",
        "symfony/mime": "^8.1.0",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/process": "^8.1.0",
        "symfony/property-access": "^8.1.0",
        "symfony/property-info": "^8.1.0",
        "symfony/runtime": "^8.1.0",
        "symfony/scheduler": "^8.1.0",
        "symfony/security-bundle": "^8.1.0",
        "symfony/serializer": "^8.1.0",
        "symfony/stimulus-bundle": "^2.36",
        "symfony/string": "^8.1.0",
        "symfony/twig-bundle": "^8.1.0",
        "symfony/validator": "^8.1.0",
        "symfony/web-link": "^8.1.0",
        "symfony/webpack-encore-bundle": "^2.4",
        "symfony/yaml": "^8.1.0",
        "symfonycasts/reset-password-bundle": "^1.24",
        "twig/extra-bundle": "^3.24",
        "twig/markdown-extra": "^3.26",
        "twig/twig": "^3.26"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpstan/phpstan": "^2.1.42",
        "phpunit/phpunit": "^13.1.12",
        "rector/rector": "^2.3.9",
        "symfony/browser-kit": "^8.1.0",
        "symfony/css-selector": "^8.1.0",
        "symfony/debug-bundle": "^8.1.0",
        "symfony/maker-bundle": "^1.67",
        "symfony/phpunit-bridge": "^8.1.0",
        "symfony/stopwatch": "^8.1.0",
        "symfony/web-profiler-bundle": "^8.1.0",
        "testcontainers/testcontainers": "^1.0.8"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*",
        "symfony/polyfill-php85": "*"
    },
    "autoload": {
        "psr-4": {
            "CodedMonkey\\Dirigent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodedMonkey\\Dirigent\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "build:standalone": "docker build . -t dirigent-standalone",
        "lint": [
            "@lint:refactor",
            "@lint:coding-style",
            "@lint:static-analysis",
            "@lint:composer",
            "@lint:yaml",
            "@lint:container",
            "@lint:templates",
            "@lint:translations"
        ],
        "lint:coding-style": "vendor/bin/php-cs-fixer fix --diff",
        "lint:composer": "composer validate",
        "lint:container": "bin/console lint:container",
        "lint:refactor": "vendor/bin/rector process",
        "lint:static-analysis": "vendor/bin/phpstan analyze",
        "lint:templates": "bin/console lint:twig templates",
        "lint:translations": "bin/console lint:translations",
        "lint:yaml": "bin/console lint:yaml .github config translations --parse-tags",
        "test": [
            "@test:php",
            "@test:images"
        ],
        "test:images": [
            "@test:images:standalone"
        ],
        "test:images:standalone": [
            "@build:standalone",
            "bin/phpunit --configuration phpunit.images.xml tests/ImageTests/Standalone"
        ],
        "test:php": [
            "@test:php:unit",
            "@test:php:functional"
        ],
        "test:php:functional": "bin/phpunit tests/FunctionalTests",
        "test:php:unit": "bin/phpunit tests/UnitTests",
        "test:setup": [
            "bin/console --env=test doctrine:database:create --if-not-exists",
            "bin/console --env=test doctrine:schema:drop --full-database --force",
            "bin/console --env=test doctrine:schema:create",
            "bin/console --env=test doctrine:fixtures:load --no-interaction"
        ]
    },
    "scripts-descriptions": {
        "build:standalone": "Build the standalone image",
        "lint": "Perform all linting validations",
        "lint:coding-style": "Validate the code style of the PHP code (using PHP-CS-Fixer)",
        "lint:composer": "Validate the Composer configuration",
        "lint:container": "Validate the Symfony container configuration",
        "lint:refactor": "Run automated code refactoring (using Rector)",
        "lint:static-analysis": "Run static analysis on the PHP code (using PHPStan)",
        "lint:templates": "Validate the Twig templates",
        "lint:translations": "Validate the translations",
        "lint:yaml": "Validate YAML files",
        "test": "Perform all code tests",
        "test:images": "Run all tests for OCI images",
        "test:images:standalone": "Run tests for the standalone OCI image",
        "test:php": "Run all PHP tests",
        "test:php:functional": "Run the functional test suite",
        "test:php:unit": "Run the unit test suite",
        "test:setup": "Prepare the Symfony test environment"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "platform": {
            "php": "8.5"
        },
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.7.x-dev"
        },
        "runtime": {
            "dotenv_path": ".env.dirigent"
        },
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    }
}
