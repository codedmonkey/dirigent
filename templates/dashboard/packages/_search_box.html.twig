{% set searchQuery = app.request.query.get('query') %}

<div class="content-search">
  <form class="form-action-search" action="{{ path('dashboard_packages') }}" method="get">
    <div class="form-group">
      <div class="form-widget">
        <i class="fas fa-search content-search-icon"></i>

        <label class="content-search-label">
          <input
            name="query"
            class="form-control {{ searchQuery is null ? 'is-blank' }}"
            type="search"
            value="{{ searchQuery ?? '' }}"
            placeholder="{{ 'Search packages'|trans }}"
            spellcheck="false"
            autocorrect="off"
            {% if autofocus ?? true %}autofocus="autofocus"{% endif %}
          >
        </label>

        {% if searchQuery %}
          {% set clearRouteParameters = app.request.attributes.get('_route_params')|filter((value, key) => key != 'query' and key != 'page') %}
          <a href="{{ path('dashboard_packages', clearRouteParameters) }}" class="content-search-reset">
            <i class="fas fa-fw fa-times"></i>
          </a>
        {% endif %}
      </div>
    </div>
  </form>
</div>
