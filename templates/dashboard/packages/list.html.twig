{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Packages{% endblock %}

{% block search_wrapper %}
  {% include 'dashboard/packages/search_box.html.twig' %}
{% endblock %}

{% block page_actions %}
  {% if is_granted('ROLE_ADMIN') %}
    <div class="global-actions">
      <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          Add Package
        </button>
        <ul class="dropdown-menu">
          {% set addVcsUrl = dashboard_path('dashboard_packages_add_vcs') %}
          <li><a class="dropdown-item" href="{{ addVcsUrl }}">Add VCS repository</a></li>
          {% set addMirroringUrl = dashboard_path('dashboard_packages_add_mirroring') %}
          <li><a class="dropdown-item" href="{{ addMirroringUrl }}">Mirror from registry</a></li>
        </ul>
      </div>
    </div>
  {% endif %}
{% endblock %}

{% block page_content %}
  <div class="d-flex align-items-center gap-2 mb-3">
    <div>{{ 'Filter by'|trans }}</div>
    <div>
      <div class="dropdown">
        <button class="btn btn-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          {{ 'Registry'|trans }}
        </button>
        <ul class="dropdown-menu">
          <li><a class="dropdown-item" href="#">{{ 'Local'|trans }}</a></li>
          {% for registry in registries %}
            {% set filterUrl = dashboard_path('dashboard_packages', {registry: registry.id}) %}
            <li><a class="dropdown-item" href="{{ filterUrl }}">{{ registry.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

 {% include 'dashboard/packages/_package_list.html.twig' %}
{% endblock %}
